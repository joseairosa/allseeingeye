{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "All Seeing Eye",
  "version": "0.0.1",
  "identifier": "dev.allseeingeye.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @aseye/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @aseye/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "All Seeing Eye",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "fullscreen": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Desktop control plane for agentic tooling",
    "longDescription": "All Seeing Eye is a single, live, searchable view of every agentic component on your machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/joseairosa/allseeingeye/releases/latest/download/latest-stable.json",
        "https://github.com/joseairosa/allseeingeye/releases/download/{{current_version}}/latest-beta.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNING_PUBLIC_KEY",
      "dialog": false
    }
  }
}
