{
  "name": "allseeingeye",
  "version": "0.0.1",
  "private": true,
  "description": "All Seeing Eye - desktop control plane for agentic tooling",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --filter @aseye/desktop dev",
    "build": "pnpm --filter @aseye/desktop build",
    "tauri:dev": "pnpm --filter @aseye/desktop tauri dev",
    "tauri:build": "pnpm --filter @aseye/desktop tauri build",
    "storybook": "pnpm --filter @aseye/ui storybook",
    "build-storybook": "pnpm --filter @aseye/ui build-storybook",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "perf:summary": "node scripts/perf-summary.mjs"
  },
  "packageManager": "pnpm@10.28.2"
}
